generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  fullName     String
  role         String      // "student", "admin", "warden"
  createdAt    DateTime    @default(now())
  
  room         Room?       @relation(fields: [roomId], references: [id])
  roomId       String?
  fees         Fee[]
  complaints   Complaint[]
  passes       Pass[]
}

model Room {
  id          String   @id @default(uuid())
  number      String   @unique
  capacity    Int      @default(2)
  occupants   User[]
}

model Fee {
  id         String   @id @default(uuid())
  month      String
  year       Int
  amountDue  Float
  amountPaid Float    @default(0)
  dueDate    DateTime
  status     String   // "paid", "pending", "overdue"
  user       User     @relation(fields: [userId], references: [id])
  userId     String
}

model Complaint {
  id          String   @id @default(uuid())
  title       String
  description String
  status      String   @default("open") // "open", "in-progress", "resolved"
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
}

model Pass {
  id           String   @id @default(uuid())
  visitorName  String
  purpose      String
  visitDate    DateTime
  visitTime    String
  qrCode       String   @unique
  status       String   @default("active") // "active", "used", "expired"
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  userId       String
}
